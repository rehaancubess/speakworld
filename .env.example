# Copy this file to .env.local. Never commit the replacement API key.
OPENAI_API_KEY=replace_with_a_new_key

# Cost-conscious defaults; override only after testing.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
OPENAI_REALTIME_VOICE_MALE=cedar
OPENAI_REALTIME_VOICE_FEMALE=marin
OPENAI_REALTIME_VOICE_HINDI_MALE=cedar
OPENAI_REALTIME_VOICE_HINDI_FEMALE=marin
OPENAI_REALTIME_VOICE_JAPANESE_MALE=echo
OPENAI_REALTIME_VOICE_JAPANESE_FEMALE=shimmer
OPENAI_REALTIME_VOICE_SPANISH_MALE=ash
OPENAI_REALTIME_VOICE_SPANISH_FEMALE=coral
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_HINDI=marin
OPENAI_TTS_VOICE_JAPANESE=shimmer
OPENAI_TTS_VOICE_SPANISH=coral
